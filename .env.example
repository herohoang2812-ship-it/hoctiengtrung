AI_API_KEY=replace_with_a_new_server_side_key
AI_BASE_URL=https://api.vilao.ai/v1
AI_MODEL=occ/claude-haiku-4-5-20251001
# VITE_AI_PROXY_URL=http://localhost:3000/api/ai

# Firebase Client configuration (Vite prefixes are exposed to the client bundle)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Bank details for generating VietQR (e.g. VITE_BANK_ID=TCB, MB, VCB)
VITE_BANK_ID=TCB
VITE_BANK_ACCOUNT=123456789
VITE_BANK_ACCOUNT_NAME="NGUYEN VAN A"

# SePay Webhook Token (custom string configured on both Vercel env and SePay Webhook settings)
SEPAY_WEBHOOK_API_KEY=goethe_sepay_secret_token

# Firebase Admin Service Account (for serverless payment webhook updates)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"